# Ignore environment variables (SANGAT PENTING)
.env
**/.env

# Ignore temporary files/images
**/temp_images/*
!**/temp_images/.gitkeep

# Ignore data database & logs
**/data/
**/mysql/
**/letsencrypt/
core/nginx-proxy/data/
core/nginx-proxy/letsencrypt/

# Ignore OS junk
.DS_Store
Thumbs.db

# Jangan push folder web Rahel
apps/rahel-web/

# Jangan push data sensitif Nginx Proxy Manager
core/nginx-proxy/data/
core/nginx-proxy/letsencrypt/

# Jangan push file log atau cache
*.log
__pycache__/

core/adguard/confdir/
core/adguard/workdir/
core/adguard/confdir/
core/adguard/workdir/
